      <property name="styleSheet">
       <string notr="true">/* Настройка самой полосы прокрутки */
QScrollBar:vertical {
    border: none;
    background: transparent; /* Сама дорожка абсолютно прозрачная */
    width: 6px;              /* Делаем её тонкой, чтобы не занимала место */
    margin: 0px;
}

/* Ползунок в обычном состоянии (полупрозрачный серый) */
QScrollBar::handle:vertical {
    background: rgba(120, 120, 120, 0.3); /* 0.3 — это 30% видимости */
    min-height: 20px;
    border-radius: 3px;                   /* Скругление, чтобы выглядело мягко */
}

/* Ползунок при наведении (становится более проявленным) */
QScrollBar::handle:vertical:hover {
    background: rgba(120, 120, 120, 0.6); /* 0.6 — это 60% видимости */
}

/* Ползунок, когда его зажали и тащат */
QScrollBar::handle:vertical:pressed {
    background: rgba(120, 120, 120, 0.8); /* 0.8 — почти плотный цвет */
}

/* Полностью убираем стрелочки сверху и снизу */
QScrollBar::add-line:vertical, QScrollBar::sub-line:vertical {
    border: none;
    background: none;
    height: 0px;
}
QScrollBar::up-arrow:vertical, QScrollBar::down-arrow:vertical {
    background: none;
}
QScrollBar::add-page:vertical, QScrollBar::sub-page:vertical {
    background: none;
}
</string>
